{
  "_comment": "Vercel configuration for Next.js TypeScript app with optimized API functions",
  "version": 2,
  "env": {
    "MONGODB_URI": "@mongodb_uri"
  },
  "functions": {
    "pages/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
} 